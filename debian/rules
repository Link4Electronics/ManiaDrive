#!/usr/bin/make -f
# -*- makefile -*-
# Sample debian/rules that uses debhelper.
# This file was originally written by Joey Hess and Craig Small.
# As a special exception, when this file is copied by dh-make into a
# dh-make output file, you may use that output file without restriction.
# This special exception was added by Craig Small in version 0.37 of dh-make.

# Uncomment this to turn on verbose mode.
export DH_VERBOSE=1


# These are used for cross-compiling and for saving the configure script
# from having to guess our platform (since we know it already)
DEB_HOST_GNU_TYPE   ?= $(shell dpkg-architecture -qDEB_HOST_GNU_TYPE)
DEB_BUILD_GNU_TYPE  ?= $(shell dpkg-architecture -qDEB_BUILD_GNU_TYPE)


CFLAGS = -Wall -g

ifneq (,$(findstring noopt,$(DEB_BUILD_OPTIONS)))
	CFLAGS += -O0
else
	CFLAGS += -O2
endif

configure:
	# Configure is not actual configure, but it downloads and compiles libphp5 and ODE
	#http://wiki.raydium.org/wiki/ManiaDriveCompilation
	#./configure


build: build-stamp

build-stamp: 
	# Configure is not actual configure, but it downloads and compiles libphp5 and ODE
	#http://wiki.raydium.org/wiki/ManiaDriveCompilation
	./configure --disable-x
	dh_testdir

	patch < kids_mode.patch
	patch < editor_start.patch

	#'make' is only for compiling tests
	DISABLE_AUTORUN=1 ./odyncomp.sh mania_drive.c
	mv test mania.bin

	DISABLE_AUTORUN=1 ./odyncomp.sh mania2.c
	mv test level_editor.bin
	touch $@

clean:
	dh_testdir
	dh_testroot
	rm -f build-stamp
	dh_clean

install: build
	dh_testdir
	dh_testroot
	dh_clean -k
	dh_installdirs

	# Folders
	install -d ${CURDIR}/debian/maniadrive/opt/maniadrive
	#Binaries
	install ${CURDIR}/mania.bin ${CURDIR}/debian/maniadrive/opt/maniadrive/
	install ${CURDIR}/level_editor.bin ${CURDIR}/debian/maniadrive/opt/maniadrive/

	#Libraries
	#ray-php
	install -d ${CURDIR}/debian/maniadrive/opt/maniadrive/rayphp/r3s
	install ${CURDIR}/rayphp/*.* ${CURDIR}/debian/maniadrive/opt/maniadrive/rayphp
	install ${CURDIR}/rayphp/r3s/*.* ${CURDIR}/debian/maniadrive/opt/maniadrive/rayphp/r3s

	#raydium
	install ${CURDIR}/libraydium.so.0.0 ${CURDIR}/debian/maniadrive/opt/maniadrive/libraydium.so.0

	#Icon and desktop files
	install -d ${CURDIR}/debian/maniadrive/usr/share/icons/hicolor/192x192/apps/
	install -d ${CURDIR}/debian/maniadrive/usr/share/applications
	install ${CURDIR}/debian/icon.png ${CURDIR}/debian/maniadrive/usr/share/icons/hicolor/192x192/apps/maniadrive.png
	install ${CURDIR}/debian/maniadrive.desktop ${CURDIR}/debian/maniadrive/usr/share/applications
	install ${CURDIR}/debian/maniadrive_editor.desktop ${CURDIR}/debian/maniadrive/usr/share/applications

	#Start-script
	install -d ${CURDIR}/debian/maniadrive/usr/bin/
	install ${CURDIR}/debian/start.sh ${CURDIR}/debian/maniadrive/usr/bin/maniadrive
	install ${CURDIR}/debian/start_editor.sh ${CURDIR}/debian/maniadrive/usr/bin/maniadrive_editor

	#Other files
	install ${CURDIR}/*.php ${CURDIR}/debian/maniadrive/opt/maniadrive/
	install ${CURDIR}/mania_drive.story.beg ${CURDIR}/debian/maniadrive/opt/maniadrive/
	install ${CURDIR}/mania_drive.story.pro ${CURDIR}/debian/maniadrive/opt/maniadrive/

	#Licence
	install ${CURDIR}/COPYING ${CURDIR}/debian/maniadrive/opt/maniadrive/


# Build architecture-independent files here.
binary-indep: build install
# We have nothing to do by default.

# Build architecture-dependent files here.
binary-arch: build install
	dh_testdir
	dh_testroot
#	dh_installchangelogs ChangeLog
#	dh_installdocs
#	dh_installexamples
#	dh_install
#	dh_installmenu
#	dh_installdebconf
#	dh_installlogrotate
#	dh_installemacsen
#	dh_installpam
#	dh_installmime
#	dh_python
#	dh_installinit
#	dh_installcron
#	dh_installinfo
#	dh_installman
#	dh_link
#	dh_strip
#	dh_compress
#	dh_fixperms
#	dh_perl
	dh_makeshlibs
	dh_installdeb
	LD_LIBRARY_PATH=. dh_shlibdeps
	dh_gencontrol
	dh_md5sums
	dh_builddeb

binary: binary-indep binary-arch
.PHONY: build clean binary-indep binary-arch binary install
